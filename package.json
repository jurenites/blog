{
  "name": "blog-jurenites",
  "private": true,
  "version": "0.1.0",
  "description": "Storybook and frontend component workspace for the Blog jurenites Drupal theme.",
  "scripts": {
    "build:tokens": "node scripts/build-tokens.mjs",
    "figma:prepare": "npm run build:tokens",
    "build:theme": "npm run build:tokens && node scripts/build-theme.mjs",
    "build:all": "npm run build:tokens && node scripts/build-theme.mjs && npm run build-storybook",
    "docs:check": "node scripts/check-docs-freshness.mjs",
    "storybook": "npm run build:tokens && storybook dev -p 6006 --host 0.0.0.0 --no-open",
    "build-storybook": "npm run build:tokens && storybook build"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/html-vite": "8.6.18",
    "esbuild": "^0.25.0",
    "sass": "^1.100.0",
    "storybook": "8.6.18",
    "vite": "^6.3.5"
  }
}
